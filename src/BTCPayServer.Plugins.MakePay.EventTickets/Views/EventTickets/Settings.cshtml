@model EventTicketSettings
@{
    var storeId = ViewData["StoreId"]?.ToString();
    var previewEventUrl = ViewData["PreviewEventUrl"]?.ToString();
    var canonicalPath = string.IsNullOrWhiteSpace(previewEventUrl)
        ? $"/stores/{storeId}/events"
        : previewEventUrl;
    var canonicalPublicUrl = Uri.TryCreate(canonicalPath, UriKind.Absolute, out var absoluteCanonicalUrl)
        ? absoluteCanonicalUrl.ToString()
        : $"{Context.Request.Scheme}://{Context.Request.Host}{(canonicalPath.StartsWith('/') ? string.Empty : "/")}{canonicalPath}";
    var brandedPublicUrl = Uri.TryCreate(canonicalPublicUrl, UriKind.Absolute, out var canonicalUri)
        ? $"https://tickets.yourdomain.com{canonicalUri.PathAndQuery}"
        : $"https://tickets.yourdomain.com/stores/{storeId}/events";
}
<style>
    .ticket-settings-header{display:flex;align-items:flex-start;justify-content:space-between;gap:20px;margin-bottom:24px}.ticket-settings-header p{max-width:680px}.ticket-settings-actions{display:flex;flex-wrap:wrap;gap:8px}.ticket-settings-card{height:100%}.ticket-settings-card h4{margin-bottom:4px}.ticket-settings-card>.text-muted{margin-bottom:22px}.ticket-domain-guide{border:1px solid var(--btcpay-border-color,rgba(122,134,151,.35))}.ticket-domain-guide-head{display:flex;align-items:flex-start;justify-content:space-between;gap:18px}.ticket-domain-badge{white-space:nowrap}.ticket-domain-url{display:block;padding:10px 12px;border:1px solid var(--btcpay-border-color,rgba(122,134,151,.35));border-radius:8px;background:var(--btcpay-bg-tile-bg,rgba(122,134,151,.08));overflow-wrap:anywhere}.ticket-domain-guide details{border-top:1px solid var(--btcpay-border-color,rgba(122,134,151,.28));padding-top:14px}.ticket-domain-guide summary{cursor:pointer;font-weight:700}.ticket-domain-guide pre{margin:12px 0 0;padding:12px;border-radius:8px;background:#101828;color:#f2f4f7;white-space:pre-wrap;overflow-wrap:anywhere}.ticket-domain-links{display:flex;flex-wrap:wrap;gap:14px}.theme-editor-dialog{width:100vw;height:100vh;max-width:none;max-height:none;margin:0;border:0;padding:0;background:#101828;color:#fff}.theme-editor-dialog::backdrop{background:rgba(16,24,40,.8)}.theme-editor-shell{height:100%;display:grid;grid-template-rows:auto 1fr}.theme-editor-header{display:flex;align-items:center;justify-content:space-between;gap:18px;padding:14px 18px;border-bottom:1px solid #344054;background:#101828}.theme-editor-header strong{font-size:1.05rem}.theme-editor-header-actions,.theme-editor-toolbar,.theme-editor-state{display:flex;gap:8px;align-items:center}.theme-editor-header button,.theme-editor-toolbar button,.theme-editor-state button{border:1px solid #475467;background:#1d2939;color:#fff;border-radius:8px;padding:8px 11px;font-weight:700}.theme-editor-header button.primary{background:#155eef;border-color:#155eef}.theme-editor-body{min-height:0;display:grid;grid-template-columns:330px 1fr}.theme-editor-controls{overflow:auto;background:#1d2939;padding:20px;border-right:1px solid #344054}.theme-editor-controls h3{font-size:.76rem;letter-spacing:.09em;text-transform:uppercase;color:#98a2b3;margin:24px 0 12px}.theme-editor-controls h3:first-child{margin-top:0}.theme-editor-controls label{display:block;font-size:.8rem;font-weight:700;margin:0 0 6px}.theme-editor-controls input,.theme-editor-controls select,.theme-editor-controls textarea{width:100%;border:1px solid #475467;border-radius:8px;background:#101828;color:#fff;padding:9px 10px;margin-bottom:12px}.theme-editor-controls input[type=color]{height:42px;padding:4px}.theme-editor-color-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}.theme-editor-preview{min-width:0;min-height:0;display:grid;grid-template-rows:auto 1fr;background:#344054}.theme-editor-toolbar{justify-content:space-between;padding:10px 14px;background:#1d2939}.theme-editor-toolbar button.is-active,.theme-editor-state button.is-active{background:#155eef;border-color:#155eef}.theme-editor-canvas{display:grid;place-items:center;overflow:auto;padding:20px}.theme-editor-frame-wrap{width:100%;height:100%;min-height:600px;transition:width .2s ease}.theme-editor-frame-wrap.is-mobile{width:390px;max-width:100%;height:760px;min-height:0}.theme-editor-frame{display:block;width:100%;height:100%;border:0;background:#fff;box-shadow:0 18px 50px rgba(0,0,0,.32)}@@media(max-width:850px){.theme-editor-body{grid-template-columns:1fr}.theme-editor-controls{display:none}.theme-editor-state{overflow:auto}.theme-editor-toolbar{align-items:flex-start;flex-direction:column}.ticket-settings-header,.ticket-domain-guide-head{flex-direction:column}}
</style>
<div class="ticket-settings-header">
    <div><h2 class="mb-1">Event ticket experience</h2><p class="text-muted mb-0">Shape the public ticket shop, checkout, confirmation, delivery, and wallet experience. The live editor previews every checkout state without saving.</p></div>
    <div class="ticket-settings-actions"><button type="button" class="btn btn-primary" id="open-theme-editor">Open live editor</button>@if(previewEventUrl is not null){<a class="btn btn-secondary" href="@previewEventUrl" target="_blank">View ticket page</a>}<a class="btn btn-secondary" asp-action="Index" asp-route-storeId="@storeId">Back</a></div>
</div>
<partial name="_StatusMessage" />
<section class="bg-tile rounded p-4 mb-4 ticket-domain-guide" aria-labelledby="ticket-domain-guide-title">
    <div class="ticket-domain-guide-head">
        <div>
            <h4 id="ticket-domain-guide-title" class="mb-1">Use your own domain</h4>
            <p class="text-muted mb-0">Connect a dedicated hostname such as <code>tickets.yourdomain.com</code>. DNS and HTTPS are server-owner responsibilities because they run before this plugin receives a request.</p>
        </div>
        <span class="badge bg-info text-dark ticket-domain-badge">Server administrator required</span>
    </div>
    <div class="row g-3 mt-1">
        <div class="col-lg-6">
            <div class="small text-muted mb-1">Current public URL</div>
            <code class="ticket-domain-url">@canonicalPublicUrl</code>
        </div>
        <div class="col-lg-6">
            <div class="small text-muted mb-1">Branded hostname with the current route</div>
            <code class="ticket-domain-url">@brandedPublicUrl</code>
        </div>
    </div>
    <div class="alert alert-warning mt-3 mb-3">
        <strong>DNS alone does not remove the store ID.</strong> This plugin currently uses store-scoped routes. A clean URL such as <code>https://tickets.yourdomain.com/events/&lt;event-slug&gt;</code> additionally needs native host-aware plugin routes or a carefully configured external proxy that forwards every ticket, checkout, asset, modal, and callback route. BTCPay's “map domain to app” control does not apply yet because Event Tickets is not registered as a BTCPay App.
    </div>
    <details class="mb-3">
        <summary>Server-owner checklist for a branded hostname</summary>
        <ol class="mt-3 mb-2">
            <li>Before changing BTCPay, create and verify the domain's A/AAAA record, or a CNAME for a subdomain, so it resolves to the BTCPay server or its external proxy.</li>
            <li>Add the new hostname without removing any existing entries from <code>BTCPAY_ADDITIONAL_HOSTS</code>, then rerun the Docker setup as root.</li>
            <li>Open the branded version of the current URL above and confirm that HTTPS, ticket selection, BTCPay checkout, status polling, PDF delivery, and wallet links all work.</li>
        </ol>
        <pre><code># Run from the btcpayserver-docker installation directory as root.
# Keep every hostname that is already configured.
export BTCPAY_ADDITIONAL_HOSTS="&lt;all-existing-additional-hosts&gt;,tickets.yourdomain.com"
. ./btcpay-setup.sh -i</code></pre>
        <p class="small text-muted mt-2 mb-0">Do not add an unresolved hostname: BTCPay warns that a failed Let's Encrypt request can affect certificate renewal for the other configured domains. A CNAME by itself is not enough—the receiving proxy must accept the hostname and present its TLS certificate.</p>
        <p class="small text-muted mt-2 mb-0"><code>BTCPAY_ADDITIONAL_HOSTS</code> aliases the whole BTCPay Server, not only this store. Other BTCPay and store-scoped public routes remain reachable on that hostname; do not treat it as domain-to-store isolation.</p>
    </details>
    <p class="mb-2"><strong>Use a dedicated subdomain when possible.</strong> If the apex domain already hosts a website, that website's reverse proxy or CDN must own the <code>/events</code> routing. Separate ticket and download subdomains also avoid BTCPay's one-domain-to-one-app constraint if native app mapping is added later.</p>
    <div class="ticket-domain-links small">
        <a href="https://docs.btcpayserver.org/Docker/#environment-variables" target="_blank" rel="noopener noreferrer">BTCPay Docker domain settings</a>
        <a href="https://docs.btcpayserver.org/FAQ/Apps/#how-to-map-a-domain-name-to-an-app" target="_blank" rel="noopener noreferrer">How BTCPay maps domains to Apps</a>
        <a href="https://docs.btcpayserver.org/FAQ/Deployment/#can-i-use-an-existing-nginx-server-as-a-reverse-proxy-with-ssl-termination" target="_blank" rel="noopener noreferrer">External reverse-proxy requirements</a>
    </div>
</section>
<form method="post" enctype="multipart/form-data" asp-action="SaveSettings" asp-route-storeId="@storeId" id="ticket-settings-form">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="row g-4">
        <div class="col-xl-6">
            <section class="bg-tile rounded p-4 ticket-settings-card">
                <h4>Brand &amp; storefront</h4><p class="text-muted">Logo, browser icon, event hero, public copy, typography, and layout.</p>
                <div class="form-group"><label asp-for="StorefrontTitle" class="form-label">Storefront name</label><input asp-for="StorefrontTitle" class="form-control"></div>
                <div class="form-group"><label asp-for="StorefrontDescription" class="form-label">Storefront description</label><textarea asp-for="StorefrontDescription" class="form-control" rows="2"></textarea></div>
                <div class="row"><div class="col-md-6 form-group"><label asp-for="LogoUrl" class="form-label">Logo URL</label><input asp-for="LogoUrl" class="form-control" placeholder="https://..."></div><div class="col-md-6 form-group"><label asp-for="FaviconUrl" class="form-label">Browser favicon URL</label><input asp-for="FaviconUrl" type="url" class="form-control" placeholder="https://example.com/favicon.png"><div class="form-text">Use an absolute HTTP(S) URL to a square ICO, PNG, or SVG. Browsers typically display it at 16–32 px.</div><span asp-validation-for="FaviconUrl" class="text-danger"></span></div></div>
                <div class="form-group"><label asp-for="HeroImageUrl" class="form-label">Default hero image URL</label><input asp-for="HeroImageUrl" class="form-control" placeholder="https://..."></div>
                <div class="form-group"><label asp-for="HeroHeadline" class="form-label">Hero headline</label><input asp-for="HeroHeadline" class="form-control"></div>
                <div class="form-group"><label asp-for="HeroSubheadline" class="form-label">Hero supporting copy</label><textarea asp-for="HeroSubheadline" class="form-control" rows="2"></textarea></div>
                <div class="row"><div class="col-md-6 form-group"><label asp-for="TicketPageTitle" class="form-label">Ticket selector title</label><input asp-for="TicketPageTitle" class="form-control"></div><div class="col-md-6 form-group"><label asp-for="TicketPageSubtitle" class="form-label">Ticket selector subtitle</label><input asp-for="TicketPageSubtitle" class="form-control"></div></div>
                <div class="row"><div class="col-md-4 form-group"><label asp-for="FontStyle" class="form-label">Typeface style</label><select asp-for="FontStyle" asp-items="Html.GetEnumSelectList<TicketFontStyle>()" class="form-select"></select></div><div class="col-md-4 form-group"><label asp-for="BrandPanelWidth" class="form-label">Hero width (%)</label><input asp-for="BrandPanelWidth" class="form-control"></div><div class="col-md-4 form-group"><label asp-for="Currency" class="form-label"></label><input asp-for="Currency" class="form-control"></div></div>
                <div class="row g-3"><div class="col-6 col-md-4"><label asp-for="AccentColor" class="form-label">Accent</label><input asp-for="AccentColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-4"><label asp-for="AccentTextColor" class="form-label">Button text</label><input asp-for="AccentTextColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-4"><label asp-for="BrandTextColor" class="form-label">Hero text</label><input asp-for="BrandTextColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-4"><label asp-for="PageBackgroundColor" class="form-label">Page</label><input asp-for="PageBackgroundColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-4"><label asp-for="SurfaceColor" class="form-label">Cards</label><input asp-for="SurfaceColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-4"><label asp-for="TextColor" class="form-label">Text</label><input asp-for="TextColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-4"><label asp-for="MutedColor" class="form-label">Muted text</label><input asp-for="MutedColor" type="color" class="form-control form-control-color w-100"></div></div>
            </section>
        </div>
        <div class="col-xl-6">
            <section class="bg-tile rounded p-4 ticket-settings-card">
                <h4>Checkout &amp; completion</h4><p class="text-muted">Reservation timing, buyer fields, promotions, policies, and success copy.</p>
                <div class="row"><div class="col-md-4 form-group"><label asp-for="CheckoutMinutes" class="form-label">Reservation minutes</label><input asp-for="CheckoutMinutes" class="form-control"></div><div class="col-md-4 form-group"><label asp-for="TimerColor" class="form-label">Timer color</label><input asp-for="TimerColor" type="color" class="form-control form-control-color w-100"></div><div class="col-md-4 form-group"><label asp-for="TimerTextColor" class="form-label">Timer text</label><input asp-for="TimerTextColor" type="color" class="form-control form-control-color w-100"></div></div>
                <div class="form-check mb-2"><input asp-for="ShowCountdown" class="form-check-input"><label asp-for="ShowCountdown" class="form-check-label">Show checkout countdown</label></div>
                <div class="form-check mb-2"><input asp-for="RequirePhone" class="form-check-input"><label asp-for="RequirePhone" class="form-check-label">Require buyer phone</label></div>
                <div class="form-check mb-2"><input asp-for="RequireCountry" class="form-check-input"><label asp-for="RequireCountry" class="form-check-label">Require buyer country</label></div>
                <div class="form-check mb-3"><input asp-for="CollectCompany" class="form-check-input"><label asp-for="CollectCompany" class="form-check-label">Collect company details</label></div>
                <div class="form-group"><label asp-for="AttendeeNotice" class="form-label">Attendee notice</label><textarea asp-for="AttendeeNotice" class="form-control" rows="2"></textarea></div>
                <div class="row"><div class="col-md-6 form-group"><label asp-for="PromoCode" class="form-label">Promotion code</label><input asp-for="PromoCode" class="form-control" autocomplete="off"></div><div class="col-md-6 form-group"><label asp-for="PromoPercent" class="form-label">Discount percent</label><input asp-for="PromoPercent" class="form-control"></div></div>
                <div class="form-group"><label asp-for="PromoDescription" class="form-label">Promotion help text</label><input asp-for="PromoDescription" class="form-control"></div>
                <div class="row"><div class="col-md-6 form-group"><label asp-for="PrivacyUrl" class="form-label">Privacy policy URL</label><input asp-for="PrivacyUrl" class="form-control"></div><div class="col-md-6 form-group"><label asp-for="TermsUrl" class="form-label">Terms URL</label><input asp-for="TermsUrl" class="form-control"></div></div>
                <div class="form-group"><label asp-for="ConfirmationTitle" class="form-label">Confirmation title</label><input asp-for="ConfirmationTitle" class="form-control"></div>
                <div class="form-group"><label asp-for="ConfirmationMessage" class="form-label">Confirmation message</label><textarea asp-for="ConfirmationMessage" class="form-control" rows="2"></textarea></div>
                <div class="form-group"><label asp-for="FooterText" class="form-label">Public footer text</label><textarea asp-for="FooterText" class="form-control" rows="2"></textarea></div>
            </section>
        </div>
        <div class="col-xl-6">
            <section class="bg-tile rounded p-4 ticket-settings-card">
                <h4>Email &amp; PDF delivery</h4><p class="text-muted">Send a protected ticket URL and optional QR-enabled PDF through BTCPay SMTP or Resend.</p>
                <div class="form-group"><label asp-for="EmailProvider" class="form-label"></label><select asp-for="EmailProvider" asp-items="Html.GetEnumSelectList<TicketEmailProvider>()" class="form-select"></select></div>
                <div class="form-group"><label class="form-label">Resend API key</label><input name="resendApiKey" type="password" autocomplete="new-password" class="form-control" placeholder="Leave blank to keep existing key"></div>
                <div class="form-group"><label asp-for="ResendFrom" class="form-label">Resend from</label><input asp-for="ResendFrom" class="form-control" placeholder="Tickets <tickets@example.com>"></div>
                <div class="form-group"><label asp-for="EmailSubject" class="form-label"></label><input asp-for="EmailSubject" class="form-control"></div>
                <div class="form-group"><label asp-for="EmailHtml" class="form-label">HTML email template</label><textarea asp-for="EmailHtml" rows="9" class="form-control font-monospace"></textarea><div class="form-text">Available: {EventName}, {EventDate}, {Venue}, {OrderUrl}</div></div>
                <div class="form-check"><input asp-for="AttachPdf" class="form-check-input"><label asp-for="AttachPdf" class="form-check-label">Attach QR-enabled tickets PDF</label></div>
                <div class="form-check"><input asp-for="DeliverOnProcessing" class="form-check-input"><label asp-for="DeliverOnProcessing" class="form-check-label">Deliver at Processing (higher payment risk)</label></div>
            </section>
        </div>
        <div class="col-xl-6">
            <section class="bg-tile rounded p-4 ticket-settings-card">
                <h4>Apple &amp; Google Wallet</h4><p class="text-muted">Wallet credentials remain encrypted with BTCPay data protection.</p>
                <h5>Apple Wallet</h5>
                <div class="row"><div class="col-md-6 form-group"><label asp-for="ApplePassTypeIdentifier" class="form-label"></label><input asp-for="ApplePassTypeIdentifier" class="form-control" placeholder="pass.com.example.tickets"></div><div class="col-md-6 form-group"><label asp-for="AppleTeamIdentifier" class="form-label"></label><input asp-for="AppleTeamIdentifier" class="form-control"></div></div>
                <div class="form-group"><label asp-for="AppleOrganizationName" class="form-label"></label><input asp-for="AppleOrganizationName" class="form-control"></div>
                <div class="row"><div class="col-md-6 form-group"><label class="form-label">Signing certificate (.p12)</label><input name="appleP12" type="file" accept=".p12,application/x-pkcs12" class="form-control"></div><div class="col-md-6 form-group"><label class="form-label">Certificate password</label><input name="appleP12Password" type="password" autocomplete="new-password" class="form-control"></div></div>
                <h5 class="mt-3">Google Wallet</h5>
                <div class="row"><div class="col-md-6 form-group"><label asp-for="GoogleIssuerId" class="form-label"></label><input asp-for="GoogleIssuerId" class="form-control"></div><div class="col-md-6 form-group"><label asp-for="GoogleClassId" class="form-label"></label><input asp-for="GoogleClassId" class="form-control" placeholder="issuerId.classSuffix"></div></div>
                <div class="form-group"><label class="form-label">Service account JSON</label><textarea name="googleServiceAccountJson" rows="6" class="form-control font-monospace" placeholder="Leave blank to keep existing credentials"></textarea></div>
            </section>
        </div>
        <div class="col-12">
            <section class="bg-tile rounded p-4">
                <h4>Analytics &amp; ecommerce events</h4>
                <p class="text-muted">Connect one Google provider without exposing customer data. Ticket pages push GA4 ecommerce events for product views, selection, cart, checkout, BTCPay payment, and confirmed purchases.</p>
                <div class="row">
                    <div class="col-lg-4 form-group"><label asp-for="AnalyticsProvider" class="form-label">Analytics provider</label><select asp-for="AnalyticsProvider" asp-items="Html.GetEnumSelectList<AnalyticsProvider>()" class="form-select" data-analytics-provider></select><div class="form-text">Choose either GTM or direct GA4 to avoid duplicate reporting. Disabled still keeps the local <code>dataLayer</code> event contract available.</div></div>
                    <div class="col-lg-4 form-group" data-analytics-field="gtm"><label asp-for="GoogleTagManagerContainerId" class="form-label">GTM container ID</label><input asp-for="GoogleTagManagerContainerId" class="form-control font-monospace" placeholder="GTM-ABC123" autocomplete="off"><span asp-validation-for="GoogleTagManagerContainerId" class="text-danger"></span></div>
                    <div class="col-lg-4 form-group" data-analytics-field="ga4"><label asp-for="GoogleAnalyticsMeasurementId" class="form-label">GA4 measurement ID</label><input asp-for="GoogleAnalyticsMeasurementId" class="form-control font-monospace" placeholder="G-ABC123DEF4" autocomplete="off"><span asp-validation-for="GoogleAnalyticsMeasurementId" class="text-danger"></span></div>
                </div>
                <div class="form-check mb-2"><input asp-for="RequireAnalyticsConsent" class="form-check-input"><label asp-for="RequireAnalyticsConsent" class="form-check-label">Require visitor consent before loading Google</label></div>
                <div class="form-check"><input asp-for="RespectDoNotTrack" class="form-check-input"><label asp-for="RespectDoNotTrack" class="form-check-label">Respect browser Do Not Track</label></div>
                <div class="form-text mt-3">The integration never puts buyer or attendee names, email addresses, phone numbers, access tokens, invoice IDs, payment addresses, or ticket codes in its event payloads. Purchase uses best-effort browser deduplication and a stable one-way transaction ID so GA4 can deduplicate repeated delivery. In GTM, trigger page tracking from MakePay's <code>page_view</code> event and map its sanitized <code>page_location</code>/<code>page_path</code>; do not use an All Pages auto-pageview or the browser Page URL on protected checkout and order routes.</div>
            </section>
        </div>
        <div class="col-12">
            <section class="bg-tile rounded p-4"><h4>MakePay attribution</h4><div class="form-check mb-3"><input asp-for="ShowMakePayPromotion" class="form-check-input"><label asp-for="ShowMakePayPromotion" class="form-check-label">Show MakePay promotion on public pages</label></div><div class="form-group mb-0"><label asp-for="PromotionText" class="form-label"></label><input asp-for="PromotionText" class="form-control"></div></section>
        </div>
    </div>
    <button class="btn btn-primary mt-4">Save settings</button>
</form>

<dialog class="theme-editor-dialog" id="theme-editor" aria-label="Live ticket page editor">
    <div class="theme-editor-shell">
        <header class="theme-editor-header"><div><strong>Live ticket experience editor</strong><div class="small text-muted">Changes appear instantly and save with the settings form.</div></div><div class="theme-editor-header-actions"><button type="button" id="close-theme-editor">Close</button><button type="button" class="primary" id="save-theme-editor">Save design</button></div></header>
        <div class="theme-editor-body">
            <aside class="theme-editor-controls">
                <h3>Brand</h3>
                <label for="editor-StorefrontTitle">Storefront name</label><input id="editor-StorefrontTitle" data-editor-target="StorefrontTitle">
                <label for="editor-LogoUrl">Logo URL</label><input id="editor-LogoUrl" data-editor-target="LogoUrl">
                <label for="editor-FaviconUrl">Browser favicon URL</label><input id="editor-FaviconUrl" data-editor-target="FaviconUrl" type="url" placeholder="https://example.com/favicon.png">
                <label for="editor-HeroImageUrl">Hero image URL</label><input id="editor-HeroImageUrl" data-editor-target="HeroImageUrl">
                <label for="editor-HeroHeadline">Headline</label><textarea id="editor-HeroHeadline" data-editor-target="HeroHeadline" rows="2"></textarea>
                <label for="editor-HeroSubheadline">Supporting copy</label><textarea id="editor-HeroSubheadline" data-editor-target="HeroSubheadline" rows="2"></textarea>
                <h3>Checkout copy</h3>
                <label for="editor-TicketPageTitle">Ticket page title</label><input id="editor-TicketPageTitle" data-editor-target="TicketPageTitle">
                <label for="editor-TicketPageSubtitle">Ticket page subtitle</label><textarea id="editor-TicketPageSubtitle" data-editor-target="TicketPageSubtitle" rows="2"></textarea>
                <label for="editor-ConfirmationTitle">Confirmation title</label><input id="editor-ConfirmationTitle" data-editor-target="ConfirmationTitle">
                <label for="editor-ConfirmationMessage">Confirmation message</label><textarea id="editor-ConfirmationMessage" data-editor-target="ConfirmationMessage" rows="2"></textarea>
                <h3>Layout &amp; colors</h3>
                <label for="editor-FontStyle">Typeface style</label><select id="editor-FontStyle" data-editor-target="FontStyle"><option value="0">System sans</option><option value="1">Modern sans</option><option value="2">Rounded sans</option><option value="3">Editorial serif</option><option value="4">Neo-grotesk sans</option></select>
                <label for="editor-BrandPanelWidth">Hero width</label><input id="editor-BrandPanelWidth" data-editor-target="BrandPanelWidth" type="range" min="35" max="60">
                <div class="theme-editor-color-grid">
                    <div><label for="editor-AccentColor">Accent</label><input id="editor-AccentColor" data-editor-target="AccentColor" type="color"></div>
                    <div><label for="editor-AccentTextColor">Button text</label><input id="editor-AccentTextColor" data-editor-target="AccentTextColor" type="color"></div>
                    <div><label for="editor-BrandTextColor">Hero text</label><input id="editor-BrandTextColor" data-editor-target="BrandTextColor" type="color"></div>
                    <div><label for="editor-PageBackgroundColor">Page</label><input id="editor-PageBackgroundColor" data-editor-target="PageBackgroundColor" type="color"></div>
                    <div><label for="editor-SurfaceColor">Cards</label><input id="editor-SurfaceColor" data-editor-target="SurfaceColor" type="color"></div>
                    <div><label for="editor-TextColor">Text</label><input id="editor-TextColor" data-editor-target="TextColor" type="color"></div>
                    <div><label for="editor-TimerColor">Timer</label><input id="editor-TimerColor" data-editor-target="TimerColor" type="color"></div>
                    <div><label for="editor-TimerTextColor">Timer text</label><input id="editor-TimerTextColor" data-editor-target="TimerTextColor" type="color"></div>
                </div>
            </aside>
            <section class="theme-editor-preview">
                <div class="theme-editor-toolbar"><div class="theme-editor-state"><button type="button" data-preview-state="tickets" class="is-active">Tickets</button><button type="button" data-preview-state="cart">Cart</button><button type="button" data-preview-state="checkout">Checkout</button><button type="button" data-preview-state="payment">Payment</button><button type="button" data-preview-state="success">Success</button></div><div><button type="button" data-preview-device="desktop" class="is-active">Desktop</button> <button type="button" data-preview-device="mobile">Mobile</button></div></div>
                <div class="theme-editor-canvas"><div class="theme-editor-frame-wrap"><iframe class="theme-editor-frame" id="theme-editor-frame" sandbox title="Ticket page preview"></iframe></div></div>
            </section>
        </div>
    </div>
</dialog>
<script>
(()=>{const dialog=document.getElementById('theme-editor'),form=document.getElementById('ticket-settings-form'),frame=document.getElementById('theme-editor-frame'),wrap=frame.closest('.theme-editor-frame-wrap'),editorFields=[...dialog.querySelectorAll('[data-editor-target]')];let state='tickets';
const source=id=>document.getElementById(id),value=id=>source(id)?.value||'',escapeHtml=text=>String(text||'').replace(/[&<>"]/g,char=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[char])),color=(id,fallback)=>/^#[0-9a-f]{6}$/i.test(value(id))?value(id):fallback,url=id=>{try{const parsed=new URL(value(id));return /^https?:$/.test(parsed.protocol)?parsed.href:''}catch{return''}};
const syncFromForm=()=>editorFields.forEach(field=>{const target=source(field.dataset.editorTarget);if(target)field.value=target.value});
const font=()=>({0:"system-ui,-apple-system,'Segoe UI',sans-serif",1:"'Helvetica Neue',Inter,system-ui,-apple-system,'Segoe UI',sans-serif",2:"ui-rounded,'Arial Rounded MT Bold',system-ui,sans-serif",3:"Georgia,'Times New Roman',serif",4:"Arial,Helvetica,sans-serif"}[value('FontStyle')]||"'Helvetica Neue',Inter,system-ui,sans-serif");
const stepper=step=>`<div class="steps"><b>STEP ${step} OF 4</b><div><span class="done">✓ Tickets</span><span class="${step===2?'now':step>2?'done':''}">2 Cart</span><span class="${step===3?'now':step>3?'done':''}">3 Checkout</span><span class="${step===4?'now':''}">4 Payment</span></div></div>`;
const shell=body=>`<div class="timer">14:42 &nbsp; Left to secure your tickets</div><main class="flow">${body}</main>`;
const render=()=>{const accent=color('AccentColor','#155eef'),accentText=color('AccentTextColor','#fff'),brandText=color('BrandTextColor','#fff'),page=color('PageBackgroundColor','#fff'),surface=color('SurfaceColor','#fff'),text=color('TextColor','#101828'),timer=color('TimerColor','#fec84b'),timerText=color('TimerTextColor','#101828'),image=url('HeroImageUrl'),logo=url('LogoUrl'),favicon=url('FaviconUrl'),title=escapeHtml(value('StorefrontTitle')),headline=escapeHtml(value('HeroHeadline')),sub=escapeHtml(value('HeroSubheadline')),pageTitle=escapeHtml(value('TicketPageTitle')),pageSubtitle=escapeHtml(value('TicketPageSubtitle')),confirmTitle=escapeHtml(value('ConfirmationTitle')),confirmMessage=escapeHtml(value('ConfirmationMessage'));
const css=`*{box-sizing:border-box}body{margin:0;background:${page};color:${text};font:15px/1.45 ${font()}}button{font:inherit}.split{display:grid;grid-template-columns:${Number(value('BrandPanelWidth'))||50}% 1fr;min-height:100vh}.brand{position:relative;overflow:hidden;background:${accent};color:${brandText};padding:50px;display:flex;flex-direction:column;justify-content:flex-end}.brand>img.hero{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.55}.brand-content{position:relative}.logo{max-height:45px;max-width:180px;margin-bottom:30px}.wordmark{font-weight:900;text-transform:uppercase;margin-bottom:30px}.eyebrow{font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:900}.brand h1{font-size:56px;line-height:.92;letter-spacing:-.05em;text-transform:uppercase;margin:10px 0;max-width:10ch}.brand p{max-width:36em}.selector{padding:54px 42px}.selector h2{font-size:32px;line-height:1;text-transform:uppercase;margin:0}.muted{color:#667085}.table-head,.ticket{display:grid;grid-template-columns:1fr 110px 110px;gap:18px}.table-head{border-bottom:2px solid #d0d5dd;padding:30px 0 10px;font-size:11px;font-weight:900}.ticket{padding:24px 0;border-bottom:1px solid #e4e7ec}.ticket h3{margin:0 0 6px}.qty{display:flex;gap:7px;align-items:start}.qty span{border:1px solid #d0d5dd;border-radius:8px;padding:5px 10px}.primary{background:${accent};color:${accentText};border:0;border-radius:9px;padding:13px 20px;font-weight:900}.full{width:100%;margin-top:24px}.timer{height:48px;background:${timer};color:${timerText};display:grid;place-items:center;font-weight:900}.flow{max-width:950px;margin:auto;padding:48px 24px}.steps{text-align:center;color:#98a2b3;font-size:12px;font-weight:800}.steps>div{display:flex;gap:28px;justify-content:center;margin:20px 0 38px}.steps span{padding:8px}.steps .done,.steps .now{color:${accent}}.steps .now{outline:2px solid ${accent};border-radius:999px}.card{border:1px solid #e4e7ec;border-radius:14px;background:${surface};overflow:hidden;margin-top:20px}.row{display:grid;grid-template-columns:1fr 120px 70px 110px;gap:15px;padding:16px 20px;border-top:1px solid #e4e7ec}.row.head{background:#f8fafc;border:0;font-size:11px;font-weight:900}.summary{background:#f8fafc;border:1px solid #e4e7ec;border-radius:14px;padding:18px 22px;margin-top:20px}.summary div{display:flex;justify-content:space-between;margin:7px}.form-card{border:1px solid #e4e7ec;border-radius:14px;padding:22px;margin:20px 0}.grid{display:grid;grid-template-columns:1fr 1fr;gap:15px}.field label{display:block;font-size:12px;font-weight:800;margin-bottom:5px}.field div{height:42px;border:1px solid #d0d5dd;border-radius:8px;background:${surface}}.attendee{border:6px solid ${accent};border-radius:14px;padding:16px;margin-top:20px}.pay{max-width:620px;margin:25px auto;border:1px solid #e4e7ec;border-radius:16px;background:${surface};padding:30px;text-align:center}.btcpay{height:320px;border:1px solid #d0d5dd;border-radius:12px;display:grid;place-items:center;background:#fff;color:#101828}.success{max-width:760px;margin:auto;padding:70px 24px}.success-mark{width:58px;height:58px;border-radius:50%;display:grid;place-items:center;background:#dcfae6;color:#067647;font-size:30px}.success h1{font-size:54px;letter-spacing:-.04em;margin:20px 0 8px}.pass{display:grid;grid-template-columns:1fr 180px;gap:20px;border:1px solid #e4e7ec;border-radius:16px;padding:24px;margin-top:24px}.ticket-code{background:#f8fafc;border-radius:8px;padding:10px;font-family:monospace}.qr-space{border:1px solid #d0d5dd;border-radius:12px;display:grid;place-items:center;color:#667085}@@media(max-width:600px){.split{display:block}.brand{min-height:330px;padding:28px}.brand h1{font-size:38px}.selector{padding:34px 20px}.table-head{display:none}.ticket{grid-template-columns:1fr auto}.ticket .qty{grid-column:1/-1}.flow{padding:30px 16px}.steps span{font-size:0}.steps span::first-letter{font-size:12px}.grid{grid-template-columns:1fr}.row{grid-template-columns:1fr 45px 75px}.row span:nth-child(2){display:none}.pass{grid-template-columns:1fr}.success h1{font-size:40px}}`;
let body;if(state==='tickets'){body=`<div class="split"><aside class="brand">${image?`<img class="hero" src="${escapeHtml(image)}" alt="">`:''}<div class="brand-content">${logo?`<img class="logo" src="${escapeHtml(logo)}" alt="">`:`<div class="wordmark">${title}</div>`}<h1>${headline}</h1><p>${sub}</p><b>15 AUG 2026 · DUBAI</b></div></aside><section class="selector"><div class="eyebrow">BUILDER SUMMIT 2026</div><h2>${pageTitle}</h2><p class="muted">${pageSubtitle}</p><div class="table-head"><span>Ticket</span><span>Price</span><span>Quantity</span></div><div class="ticket"><div><h3>General admission</h3><span class="muted">Full-day summit access and community sessions.</span></div><b>25 USD</b><div class="qty"><span>−</span><b>1</b><span>+</span></div></div><div class="ticket"><div><h3>Builder VIP</h3><span class="muted">Reserved seating and speaker reception.</span></div><b>75 USD</b><div class="qty"><span>−</span><b>0</b><span>+</span></div></div><button class="primary full">CONTINUE · 25 USD</button></section></div>`}else if(state==='cart'){body=shell(`${stepper(2)}<h1>Review your cart</h1><p class="muted">Your selection is reserved while the timer is running.</p><div class="card"><div class="row head"><span>TICKET</span><span>PRICE</span><span>QTY</span><span>TOTAL</span></div><div class="row"><b>General admission</b><span>25 USD</span><span>1</span><b>25 USD</b></div></div><div class="summary"><div><span>Subtotal</span><b>25 USD</b></div><div><strong>Total</strong><strong>25 USD</strong></div></div><button class="primary full">CONTINUE</button>`)}else if(state==='checkout'){body=shell(`${stepper(3)}<h1>Billing details</h1><p class="muted">We use this information for your receipt and ticket delivery.</p><div class="form-card grid">${['First name','Last name','Email','Phone number'].map(label=>`<div class="field"><label>${label}</label><div></div></div>`).join('')}</div><h2>Attendee details</h2><div class="attendee"><b style="color:${accent}">GENERAL ADMISSION · ATTENDEE 1</b><div class="form-card grid">${['First name','Last name','Nickname','Email'].map(label=>`<div class="field"><label>${label}</label><div></div></div>`).join('')}</div></div><button class="primary full">PROCEED TO PAYMENT</button>`)}else if(state==='payment'){body=shell(`${stepper(4)}<div class="pay"><h1>Complete your payment</h1><p class="muted">BTCPay is embedded securely below.</p><div class="btcpay"><div><b>BTCPay secure checkout</b><p>Invoice preview</p><button class="primary">Choose payment method</button></div></div></div>`)}else{body=`<main class="success"><div class="success-mark">✓</div><div class="eyebrow">PAYMENT CONFIRMED</div><h1>${confirmTitle}</h1><p class="muted">${confirmMessage}</p><button class="primary">DOWNLOAD ALL TICKETS AS PDF</button><div class="pass"><div><div class="eyebrow">GENERAL ADMISSION</div><h2>James Example</h2><p class="muted">15 August 2026 · Dubai Knowledge Park</p><div class="ticket-code">TKT-84AF-91CD-2026</div></div><div class="qr-space">Ticket QR</div></div></main>`}frame.srcdoc=`<!doctype html><head><meta name="viewport" content="width=device-width,initial-scale=1">${favicon?`<link rel="icon" href="${escapeHtml(favicon)}">`:''}<style>${css}</style></head><body>${body}</body>`};
if(state==='success')frame.srcdoc=frame.srcdoc.replace('grid-template-columns:1fr 180px;','grid-template-columns:1fr;').replace('<div class="success-mark">✓</div>','').replace('<div class="qr-space">Ticket QR</div>','');
if(state==='payment')frame.srcdoc=frame.srcdoc.replace('<div class="btcpay"><div><b>BTCPay secure checkout</b><p>Invoice preview</p><button class="primary">Choose payment method</button></div></div>',`<div class="btcpay"><div><img src="${location.origin}/img/btcpay-logo.svg" alt="BTCPay Server" style="display:block;width:180px;max-width:70%;margin:0 auto 22px"><p>Secure modal checkout is ready.</p><button class="primary">Open secure checkout</button></div></div>`);
editorFields.forEach(field=>field.addEventListener('input',()=>{const target=source(field.dataset.editorTarget);if(target){target.value=field.value;target.dispatchEvent(new Event('change',{bubbles:true}))}render()}));
document.getElementById('open-theme-editor').addEventListener('click',()=>{syncFromForm();render();dialog.showModal()});document.getElementById('close-theme-editor').addEventListener('click',()=>dialog.close());document.getElementById('save-theme-editor').addEventListener('click',()=>{dialog.close();form.requestSubmit()});
dialog.querySelectorAll('[data-preview-state]').forEach(button=>button.addEventListener('click',()=>{dialog.querySelectorAll('[data-preview-state]').forEach(item=>item.classList.remove('is-active'));button.classList.add('is-active');state=button.dataset.previewState;render()}));dialog.querySelectorAll('[data-preview-device]').forEach(button=>button.addEventListener('click',()=>{dialog.querySelectorAll('[data-preview-device]').forEach(item=>item.classList.remove('is-active'));button.classList.add('is-active');wrap.classList.toggle('is-mobile',button.dataset.previewDevice==='mobile')}));})();
</script>
<script>
(()=>{const provider=document.querySelector('[data-analytics-provider]'),fields={gtm:document.querySelector('[data-analytics-field="gtm"]'),ga4:document.querySelector('[data-analytics-field="ga4"]')};if(!provider)return;const update=()=>{fields.gtm.hidden=provider.value!=='1';fields.ga4.hidden=provider.value!=='2'};provider.addEventListener('change',update);update()})();
</script>
