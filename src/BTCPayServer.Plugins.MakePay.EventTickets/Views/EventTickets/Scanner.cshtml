@{var storeId=ViewData["StoreId"]?.ToString();}
<h2>Ticket scanner</h2><p class="text-muted">Camera scanning uses the browser BarcodeDetector API when available. Manual code entry always works.</p><div class="row g-4"><div class="col-lg-7"><video id="camera" class="w-100 rounded bg-dark" style="max-height:480px" playsinline muted></video><button id="start" class="btn btn-primary mt-2">Start camera</button></div><div class="col-lg-5"><div class="bg-tile rounded p-4"><label class="form-label">Gate / lane</label><input id="gate" class="form-control mb-3" placeholder="Main entrance"><label class="form-label">Ticket code</label><div class="input-group"><input id="code" class="form-control font-monospace"><button id="check" class="btn btn-primary">Check in</button></div><div id="result" class="alert mt-3" hidden></div></div></div></div><script>
const video=document.getElementById('camera'),code=document.getElementById('code'),result=document.getElementById('result');let detector,active=false;
async function check(v){const r=await fetch('@Url.Action("CheckIn","EventTicketsAdmin",new{storeId})',{method:'POST',headers:{'Content-Type':'application/json','RequestVerificationToken':document.querySelector('input[name="__RequestVerificationToken"]')?.value||''},body:JSON.stringify({code:v,gate:document.getElementById('gate').value})});const j=await r.json();result.hidden=false;result.className='alert mt-3 '+(j.success?'alert-success':'alert-danger');result.textContent=j.message+(j.attendee?' — '+j.attendee:'');if(j.success&&navigator.vibrate)navigator.vibrate(120);code.value='';setTimeout(()=>active=true,1200)}
document.getElementById('check').onclick=()=>check(code.value);code.onkeydown=e=>{if(e.key==='Enter')check(code.value)};document.getElementById('start').onclick=async()=>{if(!('BarcodeDetector'in window)){result.hidden=false;result.className='alert alert-warning mt-3';result.textContent='Camera QR detection is not supported by this browser. Use manual entry.';return}detector=new BarcodeDetector({formats:['qr_code']});video.srcObject=await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment'}});await video.play();active=true;scan()};async function scan(){if(active){const found=await detector.detect(video);if(found.length){active=false;await check(found[0].rawValue)}}requestAnimationFrame(scan)}
</script>@Html.AntiForgeryToken()
