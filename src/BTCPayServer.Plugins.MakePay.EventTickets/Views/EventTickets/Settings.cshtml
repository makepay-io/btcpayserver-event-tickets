@model EventTicketSettings
@{
    var storeId = ViewData["StoreId"]?.ToString();
    var previewEventUrl = ViewData["PreviewEventUrl"]?.ToString();
    var previewEventSlug = ViewData["PreviewEventSlug"]?.ToString();
    var canManageServerDomains = ViewData["CanManageServerDomains"] as bool? == true;
    var eventTicketsApps = ViewData["EventTicketsApps"] as IReadOnlyList<BTCPayServer.Data.AppData> ?? [];
    var mappedEventTicketsApp = ViewData["MappedEventTicketsApp"] as BTCPayServer.Data.AppData;
    var mappedDomain = ViewData["MappedDomain"]?.ToString();
    var mappedBaseUrl = ViewData["MappedBaseUrl"]?.ToString();
    var domainMappingWarning = ViewData["DomainMappingWarning"]?.ToString();
    var createEventTicketsAppUrl = ViewData["CreateEventTicketsAppUrl"]?.ToString();
    var legacyPath = string.IsNullOrWhiteSpace(previewEventSlug)
        ? $"{Context.Request.PathBase}/stores/{storeId}/events"
        : $"{Context.Request.PathBase}/stores/{storeId}/events/{previewEventSlug}";
    var legacyPublicUrl = TicketPublicUrl.ToAbsoluteHttpUrl(
        legacyPath,
        Context.Request.Scheme,
        Context.Request.Host.Value);
    var cleanPath = string.IsNullOrWhiteSpace(previewEventSlug) ? "/events" : $"/events/{previewEventSlug}";
    var canonicalPublicUrl = ViewData["CanonicalPublicUrl"]?.ToString() ?? legacyPublicUrl;
    var cleanPublicExample = string.IsNullOrWhiteSpace(mappedBaseUrl)
        ? $"https://tickets.yourdomain.com{Context.Request.PathBase}{cleanPath}"
        : mappedBaseUrl + cleanPath;
    var storefrontLabel = string.IsNullOrWhiteSpace(Model.StorefrontTitle) ? "Needs setup" : "Ready";
    var checkoutLabel = $"{Model.CheckoutMinutes}-minute reservation";
    var deliveryLabel = Model.EmailProvider == TicketEmailProvider.Resend ? "Resend + PDF" : "BTCPay SMTP + PDF";
    var analyticsLabel = Model.AnalyticsProvider switch
    {
        AnalyticsProvider.GoogleTagManager => "GTM connected",
        AnalyticsProvider.GoogleAnalytics => "GA4 connected",
        _ => "dataLayer only"
    };
    var domainLabel = mappedDomain is null ? "Default URL" : "Custom domain";
    var iconSpriteUrl = Url.Content("~/img/icon-sprite.svg");
    var btcpayLogoUrl = Url.Content("~/img/btcpay-logo.svg");
}
<style>
