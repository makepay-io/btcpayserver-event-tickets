@model TicketEvent
@{var storeId=ViewData["StoreId"]?.ToString();}
<h2>@Model.Name</h2><form method="post" asp-action="SaveEvent" asp-route-storeId="@storeId" asp-route-eventId="@Model.Id"><div asp-validation-summary="All" class="text-danger"></div><div class="row g-4"><div class="col-lg-7"><div class="form-group"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control"></div><div class="form-group"><label asp-for="Slug" class="form-label"></label><input asp-for="Slug" class="form-control"></div><div class="form-group"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" rows="6" class="form-control"></textarea></div><div class="row"><div class="col"><label asp-for="StartsAt" class="form-label"></label><input asp-for="StartsAt" type="datetime-local" class="form-control"></div><div class="col"><label asp-for="EndsAt" class="form-label"></label><input asp-for="EndsAt" type="datetime-local" class="form-control"></div></div><div class="form-group"><label asp-for="TimeZoneId" class="form-label"></label><input asp-for="TimeZoneId" class="form-control"><div class="form-text">IANA/host time zone identifier, for example Europe/London or Asia/Dubai.</div></div><div class="row"><div class="col"><label asp-for="VenueName" class="form-label"></label><input asp-for="VenueName" class="form-control"></div><div class="col"><label asp-for="VenueAddress" class="form-label"></label><input asp-for="VenueAddress" class="form-control"></div></div><div class="form-group"><label asp-for="BannerUrl" class="form-label"></label><input asp-for="BannerUrl" class="form-control"></div><div class="form-check"><input asp-for="Published" class="form-check-input"><label asp-for="Published" class="form-check-label">Published</label></div></div><div class="col-lg-5"><div class="bg-tile rounded p-4"><div class="d-flex justify-content-between"><h4>Ticket types</h4><button type="button" class="btn btn-sm btn-secondary" id="add-type">Add</button></div><div id="types">@for(var i=0;i<Model.TicketTypes.Count;i++){<div class="ticket-type border rounded p-3 mb-3"><input type="hidden" asp-for="TicketTypes[i].Id"><div class="form-group"><label class="form-label">Name</label><input asp-for="TicketTypes[i].Name" class="form-control"></div><div class="form-group"><label class="form-label">Badge</label><input asp-for="TicketTypes[i].Badge" class="form-control" placeholder="Early bird"></div><div class="form-group"><label class="form-label">Description</label><textarea asp-for="TicketTypes[i].Description" rows="3" class="form-control"></textarea></div><div class="row"><div class="col"><label class="form-label">Price</label><input asp-for="TicketTypes[i].Price" class="form-control"></div><div class="col"><label class="form-label">Compare-at price</label><input asp-for="TicketTypes[i].CompareAtPrice" class="form-control"></div><div class="col"><label class="form-label">Capacity</label><input asp-for="TicketTypes[i].Capacity" class="form-control"></div></div><div class="row mt-2"><div class="col"><label class="form-label">Max/order</label><input asp-for="TicketTypes[i].MaxPerOrder" class="form-control"></div><div class="col d-flex align-items-end"><div class="form-check mb-2"><input asp-for="TicketTypes[i].Active" class="form-check-input"><label class="form-check-label">Active</label></div></div></div></div>}</div></div></div></div><button class="btn btn-primary mt-4">Save event</button> <a class="btn btn-secondary mt-4" asp-action="Index" asp-route-storeId="@storeId">Cancel</a></form>
<template id="type-template"><div class="ticket-type border rounded p-3 mb-3"><input type="hidden" data-name="Id" value=""><div class="form-group"><label class="form-label">Name</label><input data-name="Name" class="form-control"></div><div class="form-group"><label class="form-label">Badge</label><input data-name="Badge" class="form-control"></div><div class="form-group"><label class="form-label">Description</label><textarea data-name="Description" rows="3" class="form-control"></textarea></div><div class="row"><div class="col"><label class="form-label">Price</label><input data-name="Price" value="0" class="form-control"></div><div class="col"><label class="form-label">Compare-at</label><input data-name="CompareAtPrice" class="form-control"></div><div class="col"><label class="form-label">Capacity</label><input data-name="Capacity" value="100" class="form-control"></div></div><div class="row mt-2"><div class="col"><label class="form-label">Max/order</label><input data-name="MaxPerOrder" value="10" class="form-control"></div><div class="col"><input data-name="Active" type="checkbox" value="true" checked> Active</div></div></div></template><script>document.getElementById('add-type').onclick=()=>{const i=document.querySelectorAll('.ticket-type').length,n=document.getElementById('type-template').content.cloneNode(true);n.querySelectorAll('[data-name]').forEach(x=>{x.name=`TicketTypes[${i}].${x.dataset.name}`});document.getElementById('types').append(n)}</script>
