<style>
.mp-submit-overlay{position:fixed;inset:0;z-index:2147483000;display:none;place-items:center;padding:24px;background:rgba(16,24,40,.58);backdrop-filter:blur(5px)}.mp-submit-overlay.is-visible{display:grid}.mp-submit-dialog{width:min(100%,456px);padding:52px 44px 42px;border-radius:18px;background:#fff;color:#101828;text-align:center;box-shadow:0 28px 90px rgba(16,24,40,.28)}.mp-submit-spinner{width:48px;height:48px;margin:0 auto 30px;border:5px solid #d0d5dd;border-top-color:#344054;border-radius:50%;animation:mp-submit-spin .8s linear infinite}.mp-submit-title{margin:0 0 8px;font:800 1.08rem/1.3 system-ui,-apple-system,"Segoe UI",sans-serif}.mp-submit-message{margin:0;color:#667085;font:600 .94rem/1.5 system-ui,-apple-system,"Segoe UI",sans-serif}@@keyframes mp-submit-spin{to{transform:rotate(360deg)}}
</style>
<script>
(()=>{if(window.makePaySubmissionOverlay)return;let overlay;const ensure=()=>{if(overlay)return overlay;overlay=document.createElement('div');overlay.className='mp-submit-overlay';overlay.setAttribute('role','status');overlay.innerHTML='<div class="mp-submit-dialog"><div class="mp-submit-spinner" aria-hidden="true"></div><h2 class="mp-submit-title"></h2><p class="mp-submit-message"></p></div>';document.body.appendChild(overlay);return overlay};const api={show(title='Processing…',message='This may take a moment. Please wait while we securely process your request.'){const el=ensure();if(el.classList.contains('is-visible'))return false;el.querySelector('.mp-submit-title').textContent=title;el.querySelector('.mp-submit-message').textContent=message;el.classList.add('is-visible');document.documentElement.style.overflow='hidden';return true},hide(){if(!overlay)return;overlay.classList.remove('is-visible');document.documentElement.style.overflow=''}};window.makePaySubmissionOverlay=api;document.addEventListener('submit',event=>{const form=event.target;if(!(form instanceof HTMLFormElement)||form.dataset.noLoading==='true')return;if(form.dataset.mpSubmitting==='true'){event.preventDefault();return}queueMicrotask(()=>{if(event.defaultPrevented)return;form.dataset.mpSubmitting='true';const submitter=event.submitter;api.show(submitter?.dataset.loadingTitle||form.dataset.loadingTitle||'Processing…',submitter?.dataset.loadingMessage||form.dataset.loadingMessage||'This may take a moment. Please wait while we securely process your request.');form.querySelectorAll('button[type="submit"],input[type="submit"]').forEach(control=>control.disabled=true);form.setAttribute('aria-busy','true')})});addEventListener('pageshow',()=>{document.querySelectorAll('form[data-mp-submitting]').forEach(form=>{delete form.dataset.mpSubmitting;form.removeAttribute('aria-busy');form.querySelectorAll('button[type="submit"],input[type="submit"]').forEach(control=>control.disabled=false)});api.hide()})})();
</script>
