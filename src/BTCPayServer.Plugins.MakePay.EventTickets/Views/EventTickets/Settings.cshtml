ound:#155eef;border-color:#155eef}.theme-editor-body{min-height:0;display:grid;grid-template-columns:330px 1fr}.theme-editor-controls{overflow:auto;background:#1d2939;padding:20px;border-right:1px solid #344054}.theme-editor-controls h3{font-size:.76rem;letter-spacing:.09em;text-transform:uppercase;color:#98a2b3;margin:24px 0 12px}.theme-editor-controls h3:first-child{margin-top:0}.theme-editor-controls label{display:block;font-size:.8rem;font-weight:700;margin:0 0 6px}.theme-editor-controls input,.theme-editor-controls select,.theme-editor-controls textarea{width:100%;border:1px solid #475467;border-radius:8px;background:#101828;color:#fff;padding:9px 10px;margin-bottom:12px}.theme-editor-controls input[type=color]{height:42px;padding:4px}.theme-editor-color-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}.theme-editor-preview{min-width:0;min-height:0;display:grid;grid-template-rows:auto 1fr;background:#344054}.theme-editor-toolbar{justify-content:space-between;padding:10px 14px;background:#1d2939}.theme-editor-toolbar button.is-active,.theme-editor-state button.is-active{background:#155eef;border-color:#155eef}.theme-editor-canvas{display:grid;place-items:center;overflow:auto;padding:20px}.theme-editor-frame-wrap{width:100%;height:100%;min-height:600px;transition:width .2s ease}.theme-editor-frame-wrap.is-mobile{width:390px;max-width:100%;height:760px;min-height:0}.theme-editor-frame{display:block;width:100%;height:100%;border:0;background:#fff;box-shadow:0 18px 50px rgba(0,0,0,.32)}@@media(max-width:850px){.theme-editor-state{overflow:auto}.theme-editor-toolbar{align-items:flex-start;flex-direction:column}.ticket-settings-header,.ticket-domain-guide-head{flex-direction:column}}
