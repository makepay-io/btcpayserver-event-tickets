@model EventTicketSettings
@{var storeId=ViewData["StoreId"]?.ToString();}
<h2>Delivery, branding & wallets</h2><partial name="_StatusMessage" /><form method="post" enctype="multipart/form-data" asp-action="SaveSettings" asp-route-storeId="@storeId"><div asp-validation-summary="All" class="text-danger"></div><div class="row g-4"><div class="col-lg-6"><div class="bg-tile rounded p-4"><h4>Storefront</h4><div class="form-group"><label asp-for="StorefrontTitle" class="form-label"></label><input asp-for="StorefrontTitle" class="form-control"></div><div class="form-group"><label asp-for="StorefrontDescription" class="form-label"></label><textarea asp-for="StorefrontDescription" class="form-control"></textarea></div><div class="row"><div class="col"><label asp-for="Currency" class="form-label"></label><input asp-for="Currency" class="form-control"></div><div class="col"><label asp-for="AccentColor" class="form-label"></label><input asp-for="AccentColor" type="color" class="form-control form-control-color"></div></div><div class="form-group"><label asp-for="LogoUrl" class="form-label"></label><input asp-for="LogoUrl" class="form-control"></div></div><div class="bg-tile rounded p-4 mt-4"><h4>Email & PDF</h4><div class="form-group"><label asp-for="EmailProvider" class="form-label"></label><select asp-for="EmailProvider" asp-items="Html.GetEnumSelectList<TicketEmailProvider>()" class="form-select"></select></div><div class="form-group"><label class="form-label">Resend API key</label><input name="resendApiKey" type="password" autocomplete="new-password" class="form-control" placeholder="Leave blank to keep"></div><div class="form-group"><label asp-for="ResendFrom" class="form-label"></label><input asp-for="ResendFrom" class="form-control" placeholder="Tickets <tickets@example.com>"></div><div class="form-group"><label asp-for="EmailSubject" class="form-label"></label><input asp-for="EmailSubject" class="form-control"></div><div class="form-group"><label asp-for="EmailHtml" class="form-label"></label><textarea asp-for="EmailHtml" rows="8" class="form-control font-monospace"></textarea></div><div class="form-check"><input asp-for="AttachPdf" class="form-check-input"><label asp-for="AttachPdf" class="form-check-label">Attach tickets.pdf</label></div></div></div><div class="col-lg-6"><div class="bg-tile rounded p-4"><h4>Apple Wallet</h4><div class="form-group"><label asp-for="ApplePassTypeIdentifier" class="form-label"></label><input asp-for="ApplePassTypeIdentifier" class="form-control" placeholder="pass.com.example.tickets"></div><div class="form-group"><label asp-for="AppleTeamIdentifier" class="form-label"></label><input asp-for="AppleTeamIdentifier" class="form-control"></div><div class="form-group"><label asp-for="AppleOrganizationName" class="form-label"></label><input asp-for="AppleOrganizationName" class="form-control"></div><div class="form-group"><label class="form-label">Signing certificate (.p12)</label><input name="appleP12" type="file" accept=".p12,application/x-pkcs12" class="form-control"></div><div class="form-group"><label class="form-label">Certificate password</label><input name="appleP12Password" type="password" autocomplete="new-password" class="form-control"></div></div><div class="bg-tile rounded p-4 mt-4"><h4>Google Wallet</h4><div class="form-group"><label asp-for="GoogleIssuerId" class="form-label"></label><input asp-for="GoogleIssuerId" class="form-control"></div><div class="form-group"><label asp-for="GoogleClassId" class="form-label"></label><input asp-for="GoogleClassId" class="form-control" placeholder="issuerId.classSuffix"></div><div class="form-group"><label class="form-label">Service account JSON</label><textarea name="googleServiceAccountJson" rows="6" class="form-control font-monospace" placeholder="Leave blank to keep"></textarea></div></div><div class="bg-tile rounded p-4 mt-4"><div class="form-check"><input asp-for="DeliverOnProcessing" class="form-check-input"><label asp-for="DeliverOnProcessing" class="form-check-label">Deliver at Processing (higher payment risk)</label></div><div class="form-check"><input asp-for="ShowMakePayPromotion" class="form-check-input"><label asp-for="ShowMakePayPromotion" class="form-check-label">Show MakePay promotion</label></div></div></div></div><button class="btn btn-primary mt-4">Save settings</button> <a class="btn btn-secondary mt-4" asp-action="Index" asp-route-storeId="@storeId">Back</a></form>
