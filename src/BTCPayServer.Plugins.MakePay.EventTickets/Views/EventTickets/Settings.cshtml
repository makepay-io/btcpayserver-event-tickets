<div class="mp-settings-dashboard">
    <header class="mp-settings-header">
        <div class="mp-settings-heading">
            <h2>Event ticket settings</h2>
            <p>Configure the public event shop, checkout, ticket delivery, wallets, analytics, and custom-domain experience from one focused workspace.</p>
        </div>
        <div class="mp-settings-actions">
            <a class="btn btn-secondary" asp-action="Index" asp-route-storeId="@storeId"><svg class="mp-settings-icon" aria-hidden="true"><use href="@($"{iconSpriteUrl}#back")"></use></svg>Back</a>
            @if (previewEventUrl is not null)
            {
                <a class="btn btn-secondary" href="@previewEventUrl" target="_blank" rel="noopener noreferrer"><svg class="mp-settings-icon" aria-hidden="true"><use href="@($"{iconSpriteUrl}#actions-show")"></use></svg>View ticket page</a>
            }
            <button type="button" class="btn btn-secondary" id="open-theme-editor"><svg class="mp-settings-icon" aria-hidden="true"><use href="@($"{iconSpriteUrl}#themes-light")"></use></svg>Open live editor</button>
            <button type="submit" class="btn btn-primary" form="ticket-settings-form" data-settings-submit><svg class="mp-settings-icon" aria-hidden="true"><use href="@($"{iconSpriteUrl}#done")"></use></svg>Save settings</button>
        </div>
    </header>
    <partial name="_StatusMessage" />

    <nav class="mp-settings-tabs" role="tablist" aria-label="Event ticket settings sections">
        <button type="button" class="mp-settings-tab" id="settings-tab-storefront" role="tab" aria-selected="true" aria-controls="settings-panel-storefront" data-settings-tab="storefront"><svg aria-hidden="true"><use href="@($"{iconSpriteUrl}#nav-store")"></use></svg>Storefront</button>
        <button type="button" class="mp-settings-tab" id="settings-tab-checkout" role="tab" aria-selected="false" aria-controls="settings-panel-checkout" data-settings-tab="checkout" tabindex="-1"><svg aria-hidden="true"><use href="@($"{iconSpriteUrl}#pos-cart")"></use></svg>Checkout &amp; promotions</button>
        <button type="button" class="mp-settings-tab" id="settings-tab-delivery" role="tab" aria-selected="false" aria-controls="settings-panel-delivery" data-settings-tab="delivery" tabindex="-1"><svg aria-hidden="true"><use href="@($"{iconSpriteUrl}#actions-email")"></use></svg>Delivery &amp; wallets</button>
        <button type="button" class="mp-settings-tab" id="settings-tab-analytics" role="tab" aria-selected="false" aria-controls="settings-panel-analytics" data-settings-tab="analytics" tabindex="-1"><svg aria-hidden="true"><use href="@($"{iconSpriteUrl}#nav-dashboard")"></use></svg>Analytics</button>
        <button type="button" class="mp-settings-tab" id="settings-tab-domain" role="tab" aria-selected="false" aria-controls="settings-panel-domain" data-settings-tab="domain" tabindex="-1"><svg aria-hidden="true"><use href="@($"{iconSpriteUrl}#nav-explore")"></use></svg>Custom domain</button>
    </nav>

    <section class="mp-settings-stat-grid" aria-label="Configuration status">
        <article class="mp-settings-stat"><span class="mp-settings-stat-icon"><svg aria-hidden="true"><use href="@($"{iconSpriteUrl}#nav-store")"></use></svg></span><div class="mp-settings-stat-copy"><span>Storefront</span><strong>@storefrontLabel</strong><small>Brand, hero, and ticket catalog</small></div></article>
        <article class="mp-settings-stat"><span class="mp-settings-stat-icon"><svg aria-hidden="true"><use href="@($"{iconSpriteUrl}#time")"></use></svg></span><div class="mp-settings-stat-copy"><span>Checkout</span><strong>@checkoutLabel</strong><small>Protected ticket reservation</small></div></article>
        <article class="mp-settings-stat"><span class="mp-settings-stat-icon"><svg aria-hidden="true"><use href="@($"{iconSpriteUrl}#actions-email")"></use></svg></span><div class="mp-settings-stat-copy"><span>Delivery</span><strong>@deliveryLabel</strong><small>@analyticsLabel</small></div></article>
        <article class="mp-settings-stat"><span class="mp-settings-stat-icon"><svg aria-hidden="true"><use href="@($"{iconSpriteUrl}#nav-explore")"></use></svg></span><div class="mp-settings-stat-copy"><span>Public URL</span><strong>@domainLabel</strong><small>@canonicalPublicUrl</small></div></article>
    </section>

    <form method="post" enctype="multipart/form-data" asp-action="SaveSettings" asp-route-storeId="@storeId" id="ticket-settings-form">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="All" class="alert alert-danger mp-settings-validation" tabindex="-1"></div>
        }

        <section class="mp-settings-panel is-active" id="settings-panel-storefront" role="tabpanel" aria-labelledby="settings-tab-storefront" data-settings-panel="storefront">
            <header class="mp-settings-panel-head"><div><h3>Storefront</h3><p>Manage store identity, event hero copy, typography, and public colors.</p></div><button type="button" class="btn btn-secondary" data-open-theme-editor><svg class="mp-settings-icon" aria-hidden="true"><use href="@($"{iconSpriteUrl}#themes-light")"></use></svg>Open live editor</button></header>
            <div class="mp-settings-panel-body"><div class="mp-settings-grid">
                <section class="mp-settings-section">
                    <div class="mp-settings-section-head"><div><h4>Store identity</h4><p>Name, description, logo, browser icon, and default event image.</p></div></div>
                    <div class="form-group"><label asp-for="StorefrontTitle" class="form-label">Storefront name</label><input asp-for="StorefrontTitle" class="form-control"></div>
                    <div class="form-group"><label asp-for="StorefrontDescription" class="form-label">Storefront description</label><textarea asp-for="StorefrontDescription" class="form-control" rows="3"></textarea></div>
                    <div class="form-group"><label asp-for="LogoUrl" class="form-label">Logo URL</label><input asp-for="LogoUrl" type="url" class="form-control" placeholder="https://example.com/logo.svg"><span asp-validation-for="LogoUrl" class="text-danger"></span></div>
                    <div class="form-group"><label asp-for="FaviconUrl" class="form-label">Browser favicon URL</label><input asp-for="FaviconUrl" type="url" class="form-control" placeholder="https://example.com/favicon.png"><div class="form-text">Use an absolute HTTP(S) URL to a square ICO, PNG, or SVG.</div><span asp-validation-for="FaviconUrl" class="text-danger"></span></div>
                    <div class="form-group"><label asp-for="HeroImageUrl" class="form-label">Default hero image URL</label><input asp-for="HeroImageUrl" type="url" class="form-control" placeholder="https://example.com/event-hero.jpg"><span asp-validation-for="HeroImageUrl" class="text-danger"></span></div>
                </section>
                <section class="mp-settings-section">
                    <div class="mp-settings-section-head"><div><h4>Hero &amp; selector copy</h4><p>Keep the event brand clear while guiding visitors toward tickets.</p></div></div>
                    <div class="form-group"><label asp-for="HeroHeadline" class="form-label">Hero headline</label><input asp-for="HeroHeadline" class="form-control"></div>
                    <div class="form-group"><label asp-for="HeroSubheadline" class="form-label">Hero supporting copy</label><textarea asp-for="HeroSubheadline" class="form-control" rows="3"></textarea></div>
                    <div class="form-group"><label asp-for="TicketPageTitle" class="form-label">Ticket selector title</label><input asp-for="TicketPageTitle" class="form-control"></div>
                    <div class="form-group"><label asp-for="TicketPageSubtitle" class="form-label">Ticket selector subtitle</label><textarea asp-for="TicketPageSubtitle" class="form-control" rows="2"></textarea></div>
                    <div class="row"><div class="col-md-4 form-group"><label asp-for="FontStyle" class="form-label">Typeface style</label><select asp-for="FontStyle" asp-items="Html.GetEnumSelectList<TicketFontStyle>()" class="form-select"></select></div><div class="col-md-4 form-group"><label asp-for="BrandPanelWidth" class="form-label">Hero width (%)</label><input asp-for="BrandPanelWidth" class="form-control"></div><div class="col-md-4 form-group"><label asp-for="Currency" class="form-label"></label><input asp-for="Currency" class="form-control"></div></div>
                </section>
                <section class="mp-settings-section is-wide">
                    <div class="mp-settings-section-head"><div><h4>Color system</h4><p>Colors are applied consistently across ticket selection, checkout, payment, and confirmation.</p></div></div>
                    <div class="row g-3"><div class="col-6 col-md-3"><label asp-for="AccentColor" class="form-label">Accent</label><input asp-for="AccentColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-3"><label asp-for="AccentTextColor" class="form-label">Button text</label><input asp-for="AccentTextColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-3"><label asp-for="BrandTextColor" class="form-label">Hero text</label><input asp-for="BrandTextColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-3"><label asp-for="PageBackgroundColor" class="form-label">Page</label><input asp-for="PageBackgroundColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-3"><label asp-for="SurfaceColor" class="form-label">Cards</label><input asp-for="SurfaceColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-3"><label asp-for="TextColor" class="form-label">Text</label><input asp-for="TextColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-3"><label asp-for="MutedColor" class="form-label">Muted text</label><input asp-for="MutedColor" type="color" class="form-control form-control-color w-100"></div></div>
                </section>
            </div></div>
        </section>

        <section class="mp-settings-panel" id="settings-panel-checkout" role="tabpanel" aria-labelledby="settings-tab-checkout" data-settings-panel="checkout" hidden>
            <header class="mp-settings-panel-head"><div><h3>Checkout &amp; promotions</h3><p>Configure reservation timing, required attendee fields, promotions, policies, and completion copy.</p></div></header>
            <div class="mp-settings-panel-body"><div class="mp-settings-grid">
                <section class="mp-settings-section">
                    <div class="mp-settings-section-head"><div><h4>Reservation &amp; buyer details</h4><p>Control checkout urgency and the information required for ticket delivery.</p></div></div>
                    <div class="row"><div class="col-md-4 form-group"><label asp-for="CheckoutMinutes" class="form-label">Reservation minutes</label><input asp-for="CheckoutMinutes" class="form-control"></div><div class="col-md-4 form-group"><label asp-for="TimerColor" class="form-label">Timer color</label><input asp-for="TimerColor" type="color" class="form-control form-control-color w-100"></div><div class="col-md-4 form-group"><label asp-for="TimerTextColor" class="form-label">Timer text</label><input asp-for="TimerTextColor" type="color" class="form-control form-control-color w-100"></div></div>
                    <div class="form-check mb-2"><input asp-for="ShowCountdown" class="form-check-input"><label asp-for="ShowCountdown" class="form-check-label">Show checkout countdown</label></div>
                    <div class="form-check mb-2"><input asp-for="RequirePhone" class="form-check-input"><label asp-for="RequirePhone" class="form-check-label">Require buyer phone</label></div>
                    <div class="form-check mb-2"><input asp-for="RequireCountry" class="form-check-input"><label asp-for="RequireCountry" class="form-check-label">Require buyer country</label></div>
                    <div class="form-check mb-3"><input asp-for="CollectCompany" class="form-check-input"><label asp-for="CollectCompany" class="form-check-label">Collect company details</label></div>
