@model TicketOrderViewModel
@{Layout=null;}<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><meta http-equiv="refresh" content="@(Model.Order.Status==TicketOrderStatus.Pending?"10":"")"><title>@Model.Event.Name tickets</title><style>:root{--a:@Model.Settings.AccentColor}*{box-sizing:border-box}body{margin:0;background:#fff7ed;color:#292018;font:16px/1.5 system-ui}.shell{max-width:850px;margin:auto;padding:45px 24px}.ticket{background:#fff;border:1px solid #fed7aa;border-radius:22px;padding:28px;margin:20px 0;display:grid;grid-template-columns:1fr 190px;gap:25px}.qr{width:190px}.code{font:700 15px monospace;word-break:break-all}.actions a{display:inline-block;padding:10px 14px;margin:5px;background:var(--a);color:#fff;text-decoration:none;border-radius:9px}.muted{color:#826d5b}@@media(max-width:600px){.ticket{grid-template-columns:1fr}.qr{width:100%;max-width:240px}}</style></head><body><main class="shell"><h1>@Model.Event.Name</h1><p>@Model.Event.StartsAt.ToString("dddd, dd MMMM yyyy · HH:mm")<br>@Model.Event.VenueName</p>@if(Model.Order.Status==TicketOrderStatus.Pending){<p>Waiting for payment confirmation. This page refreshes automatically.</p>}else if(Model.Order.Status==TicketOrderStatus.Cancelled){<p>This order was cancelled.</p>}else{<div class="actions">@if(Model.PdfUrl is not null){<a href="@Model.PdfUrl">Download PDF</a>}</div>@foreach(var d in Model.Tickets){<article class="ticket"><div><h2>@Model.TicketType.Name</h2><p>@d.Ticket.AttendeeName</p><p class="code">@d.Code</p><div class="actions">@if(d.AppleWalletUrl is not null){<a href="@d.AppleWalletUrl">Add to Apple Wallet</a>}@if(d.GoogleWalletUrl is not null){<a href="@d.GoogleWalletUrl">Add to Google Wallet</a>}</div></div><img class="qr" src="@d.QrDataUri" alt="Ticket QR code"></article>}}@if(Model.Settings.ShowMakePayPromotion){<p class="muted">@Model.Settings.PromotionText</p>}</main></body></html>
