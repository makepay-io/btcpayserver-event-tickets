@model TicketOrderViewModel
@{ Layout = null; }
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>@Model.Event.Name tickets</title>
    <partial name="~/Views/EventTickets/Public/_Theme.cshtml" model="Model.Settings" />
</head>
<body class="et-public">
@if (Model.Order.Status == TicketOrderStatus.Pending)
{
    <main class="et-pending"><div class="et-spinner"></div><h1>Waiting for payment confirmation</h1><p class="et-section-copy">BTCPay is still processing this order. You can return to the embedded payment or leave this page open.</p>@if(Model.Order.InvoiceId is not null){<a class="et-primary" asp-action="Payment" asp-route-storeId="@Model.Order.StoreId" asp-route-eventId="@Model.Event.Slug" asp-route-orderId="@Model.Order.Id" asp-route-accessToken="@Model.AccessToken">Return to payment</a>}</main>
}
else if (Model.Order.Status == TicketOrderStatus.Cancelled)
{
    <main class="et-pending"><h1>This order was cancelled</h1><p class="et-section-copy">No ticket was issued. Start a new order if you still want to attend.</p><a class="et-primary" asp-action="Event" asp-route-storeId="@Model.Order.StoreId" asp-route-eventId="@Model.Event.Slug">Choose tickets</a></main>
}
else
{
    <main class="et-success">
        <div class="et-success-mark" aria-hidden="true"><img src="~/imlegacy/checkmark.svg" alt=""></div>
        <p class="et-eyebrow">Payment confirmed</p>
        <h1>@Model.Settings.ConfirmationTitle</h1>
        <p class="et-success-lead">@Model.Settings.ConfirmationMessage A confirmation was sent to <strong>@Model.Order.BuyerEmail</strong>.</p>
        <div class="et-summary">
            <div class="et-summary-row"><span>Event</span><strong>@Model.Event.Name</strong></div>
            <div class="et-summary-row"><span>Date</span><strong>@Model.Event.StartsAt.ToString("ddd, dd MMM yyyy · HH:mm")</strong></div>
            <div class="et-summary-row"><span>Venue</span><strong>@Model.Event.VenueName</strong></div>
            <div class="et-summary-row total"><span>@Model.Order.Quantity ticket@(Model.Order.Quantity == 1 ? "" : "s")</span><strong>@Model.Order.Total.ToString("0.##") @Model.Order.Currency</strong></div>
        </div>
        @if (Model.PdfUrl is not null) { <div class="et-actions"><a class="et-primary" href="@Model.PdfUrl">Download all tickets as PDF</a></div> }
        <section aria-label="Tickets">
            @foreach (var display in Model.Tickets)
            {
                <article class="et-ticket-pass">
                    <div>
                        <p class="et-eyebrow">@display.TicketType.Name</p>
                        <h2>@display.Ticket.AttendeeName</h2>
                        <p class="et-ticket-meta">@Model.Event.StartsAt.ToString("dddd, dd MMMM yyyy · HH:mm")<br>@Model.Event.VenueName · @Model.Event.VenueAddress</p>
                        <div class="et-ticket-code">@display.Code</div>
                        <div class="et-wallet-actions">
                            @if (display.AppleWalletUrl is not null) { <a class="et-secondary" href="@display.AppleWalletUrl">Add to Apple Wallet</a> }
                            @if (display.GoogleWalletUrl is not null) { <a class="et-secondary" href="@display.GoogleWalletUrl">Add to Google Wallet</a> }
                        </div>
                    </div>
                    <img class="et-qr" src="@display.QrDataUri" alt="QR code for @display.Ticket.AttendeeName">
                </article>
            }
        </section>
        <partial name="~/Views/EventTickets/Public/_Footer.cshtml" model="Model.Settings" />
    </main>
}
</body>
</html>
