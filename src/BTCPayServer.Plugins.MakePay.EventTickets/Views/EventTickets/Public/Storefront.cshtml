@model EventStorefrontViewModel
@{Layout=null;}<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title>@Model.Settings.StorefrontTitle</title><style>:root{--a:@Model.Settings.AccentColor}*{box-sizing:border-box}body{margin:0;background:#fff7ed;color:#292018;font:16px/1.5 system-ui}.shell{max-width:1100px;margin:auto;padding:45px 24px}.hero{text-align:center;margin-bottom:45px}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px}.card{background:#fff;border:1px solid #fed7aa;border-radius:22px;overflow:hidden;box-shadow:0 18px 50px #7c2d1210}.banner{width:100%;aspect-ratio:16/9;object-fit:cover;background:#ffedd5}.content{padding:25px}.btn{display:inline-block;background:var(--a);color:#fff;text-decoration:none;padding:11px 18px;border-radius:10px;font-weight:750}.meta{color:#7c6655}.promo{text-align:center;color:#8a7565;margin-top:50px}</style></head><body><main class="shell"><header class="hero">@if(Model.Settings.LogoUrl is not null){<img src="@Model.Settings.LogoUrl" style="max-height:65px" alt="">}<h1>@Model.Settings.StorefrontTitle</h1><p>@Model.Settings.StorefrontDescription</p></header><section class="grid">@foreach(var e in Model.Events){<article class="card">@if(e.BannerUrl is not null){<img class="banner" src="@e.BannerUrl" alt="">}<div class="content"><h2>@e.Name</h2><p class="meta">@e.StartsAt.ToString("ddd, dd MMM yyyy · HH:mm")<br>@e.VenueName</p><p>@e.Description</p><a class="btn" asp-action="Event" asp-route-storeId="@Model.StoreId" asp-route-eventId="@e.Slug">Tickets</a></div></article>}</section>@if(Model.Settings.ShowMakePayPromotion){<footer class="promo">@Model.Settings.PromotionText</footer>}</main></body></html>
