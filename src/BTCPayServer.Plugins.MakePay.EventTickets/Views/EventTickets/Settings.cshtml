        <section class="mp-settings-panel" id="settings-panel-delivery" role="tabpanel" aria-labelledby="settings-tab-delivery" data-settings-panel="delivery" hidden>
            <header class="mp-settings-panel-head"><div><h3>Delivery, wallets &amp; check-in</h3><p>Send protected ticket links, configure wallet passes, and control the event-scoped mobile scanner.</p></div></header>
            <div class="mp-settings-panel-body"><div class="mp-settings-grid">
                <section class="mp-settings-section">
                    <div class="mp-settings-section-head"><div><h4>Email &amp; PDF</h4><p>Use BTCPay SMTP or Resend while keeping API credentials encrypted.</p></div></div>
                    <div class="form-group"><label asp-for="EmailProvider" class="form-label">Email provider</label><select asp-for="EmailProvider" asp-items="Html.GetEnumSelectList<TicketEmailProvider>()" class="form-select"></select></div>
                    <div class="form-group"><label class="form-label" for="resendApiKey">Resend API key</label><input id="resendApiKey" name="resendApiKey" type="password" autocomplete="new-password" class="form-control" placeholder="Leave blank to keep existing key"></div>
                    <div class="form-group"><label asp-for="ResendFrom" class="form-label">Resend from</label><input asp-for="ResendFrom" class="form-control" placeholder="Tickets &lt;tickets@example.com&gt;"></div>
                    <div class="form-group"><label asp-for="EmailSubject" class="form-label">Email subject</label><input asp-for="EmailSubject" class="form-control"></div>
                    <div class="form-group"><label asp-for="EmailHtml" class="form-label">HTML email template</label><textarea asp-for="EmailHtml" rows="9" class="form-control font-monospace"></textarea><div class="form-text">Available: {EventName}, {EventDate}, {Venue}, {OrderUrl}</div></div>
                    <div class="form-check mb-2"><input asp-for="AttachPdf" class="form-check-input"><label asp-for="AttachPdf" class="form-check-label">Attach QR-enabled ticket PDF</label></div>
                    <div class="form-check"><input asp-for="DeliverOnProcessing" class="form-check-input"><label asp-for="DeliverOnProcessing" class="form-check-label">Deliver at Processing (higher payment risk)</label></div>
                </section>
                <section class="mp-settings-section">
                    <div class="mp-settings-section-head"><div><h4>Apple Wallet</h4><p>Configure the pass identity and upload its signing certificate.</p></div></div>
                    <div class="form-group"><label asp-for="ApplePassTypeIdentifier" class="form-label">Pass type identifier</label><input asp-for="ApplePassTypeIdentifier" class="form-control" placeholder="pass.com.example.tickets"></div>
                    <div class="form-group"><label asp-for="AppleTeamIdentifier" class="form-label">Team identifier</label><input asp-for="AppleTeamIdentifier" class="form-control"></div>
                    <div class="form-group"><label asp-for="AppleOrganizationName" class="form-label">Organization name</label><input asp-for="AppleOrganizationName" class="form-control"></div>
                    <div class="form-group"><label class="form-label" for="appleP12">Signing certificate (.p12)</label><input id="appleP12" name="appleP12" type="file" accept=".p12,application/x-pkcs12" class="form-control"><span class="text-danger" data-upload-validation="appleP12"></span></div>
                    <div class="form-group"><label class="form-label" for="appleP12Password">Certificate password</label><input id="appleP12Password" name="appleP12Password" type="password" autocomplete="new-password" class="form-control" placeholder="Leave blank to keep existing password"></div>
                </section>
                <section class="mp-settings-section">
                    <div class="mp-settings-section-head"><div><h4>Google Wallet</h4><p>Credentials stay protected by BTCPay data protection.</p></div></div>
                    <div class="form-group"><label asp-for="GoogleIssuerId" class="form-label">Issuer ID</label><input asp-for="GoogleIssuerId" class="form-control"></div>
                    <div class="form-group"><label asp-for="GoogleClassId" class="form-label">Class ID</label><input asp-for="GoogleClassId" class="form-control" placeholder="issuerId.classSuffix"></div>
                    <div class="form-group"><label class="form-label" for="googleServiceAccountJson">Service account JSON</label><textarea id="googleServiceAccountJson" name="googleServiceAccountJson" rows="8" class="form-control font-monospace" placeholder="Leave blank to keep existing credentials"></textarea></div>
                </section>
                <section class="mp-settings-section">
                    <div class="mp-settings-section-head"><div><h4>Operational readiness</h4><p>Wallet buttons appear only when the corresponding credentials are complete.</p></div></div>
