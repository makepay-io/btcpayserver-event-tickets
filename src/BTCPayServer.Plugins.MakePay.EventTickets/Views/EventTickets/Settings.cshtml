    @@media(max-width:991.98px){.mp-settings-stat-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.mp-settings-grid{grid-template-columns:1fr}.mp-settings-section.is-wide{grid-column:auto}.theme-editor-body{grid-template-columns:300px minmax(0,1fr)}}
