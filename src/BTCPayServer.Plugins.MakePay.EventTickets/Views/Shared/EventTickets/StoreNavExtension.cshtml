@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Client
@inject IScopeProvider ScopeProvider
@{
    var storeId = ScopeProvider.GetCurrentStoreId();
}
@if (!string.IsNullOrEmpty(storeId))
{
    <li class="nav-item">
        <a permission="@Policies.CanModifyStoreSettings" layout-menu-item="EventTickets" asp-controller="EventTicketsAdmin" asp-action="Index" asp-route-storeId="@storeId">
            <svg role="img" class="icon icon-makepay-event-tickets" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3.25 6.25h17.5v3a2.75 2.75 0 0 0 0 5.5v3H3.25v-3a2.75 2.75 0 0 0 0-5.5v-3Z" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round" />
                <path d="M12 7.75v1.5m0 2v1.5m0 2v1.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <path d="M6.75 9h2.5v2.5h-2.5zm0 4h2.5v2.5h-2.5zm8-4h2.5v2.5h-2.5z" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round" />
                <path d="M14.75 13.25H16v1.25h-1.25zm2 0H18v1.25h-1.25zm0 2H18v1.25h-1.25z" fill="currentColor" />
            </svg>
            <span>Event Tickets</span>
        </a>
    </li>
}
