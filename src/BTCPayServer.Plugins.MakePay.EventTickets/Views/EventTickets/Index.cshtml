@model EventTicketsDashboardViewModel
@{ViewData.SetActivePage("EventTickets","Event Tickets","Event Tickets");}
<div class="sticky-header d-flex justify-content-between align-items-center"><h2 class="mb-0">Event Tickets</h2><div class="d-flex gap-2"><a class="btn btn-secondary" target="_blank" asp-controller="EventTicketsPublic" asp-action="Storefront" asp-route-storeId="@Model.StoreId">View store</a><a class="btn btn-secondary" asp-action="Scanner" asp-route-storeId="@Model.StoreId">Open scanner</a><a class="btn btn-secondary" asp-action="Settings" asp-route-storeId="@Model.StoreId">Delivery & wallets</a><a class="btn btn-primary" asp-action="Event" asp-route-storeId="@Model.StoreId">Add event</a></div></div><partial name="_StatusMessage" />
<div class="row g-3 mb-4"><div class="col"><div class="bg-tile rounded p-3"><div class="text-muted">Events</div><div class="h3">@Model.Events.Count</div></div></div><div class="col"><div class="bg-tile rounded p-3"><div class="text-muted">Tickets sold</div><div class="h3">@Model.Tickets.Count</div></div></div><div class="col"><div class="bg-tile rounded p-3"><div class="text-muted">Checked in</div><div class="h3">@Model.Tickets.Count(t=>t.CheckedInAt is not null)</div></div></div></div>
<h4>Events</h4><div class="table-responsive mb-5"><table class="table align-middle"><thead><tr><th>Event</th><th>Date</th><th>Venue</th><th>Sold</th><th></th></tr></thead><tbody>@if(!Model.Events.Any()){<tr><td colspan="5" class="text-muted py-4">Create your first event.</td></tr>}@foreach(var e in Model.Events){<tr><td><strong>@e.Name</strong><div class="small text-muted">/@e.Slug · @(e.Published?"Published":"Draft")</div></td><td>@e.StartsAt.ToBrowserDate()</td><td>@e.VenueName</td><td>@Model.Tickets.Count(t=>t.EventId==e.Id)</td><td class="text-end"><a class="btn btn-sm btn-secondary" target="_blank" asp-controller="EventTicketsPublic" asp-action="Event" asp-route-storeId="@Model.StoreId" asp-route-eventId="@e.Id">Store</a> <a class="btn btn-sm btn-secondary" target="_blank" asp-controller="EventTicketsPublic" asp-action="Pos" asp-route-storeId="@Model.StoreId" asp-route-eventId="@e.Id">POS</a> <a class="btn btn-sm btn-primary" asp-action="Event" asp-route-storeId="@Model.StoreId" asp-route-eventId="@e.Id">Edit</a></td></tr>}</tbody></table></div>
<h4>Recent orders</h4><div class="table-responsive"><table class="table"><thead><tr><th>Created</th><th>Customer</th><th>Quantity</th><th>Status</th><th>Invoice</th><th>Email</th></tr></thead><tbody>@foreach(var o in Model.Orders){<tr><td>@o.CreatedAt.ToBrowserDate()</td><td>@o.BuyerName<div class="small text-muted">@o.BuyerEmail</div></td><td>@o.Quantity</td><td>@o.Status</td><td>@if(o.InvoiceId is not null){<a asp-controller="UIInvoice" asp-action="Invoice" asp-route-invoiceId="@o.InvoiceId">@o.InvoiceId</a>}</td><td>@(o.DeliverySent?"Sent":"—")</td></tr>}</tbody></table></div>
<div class="alert alert-info">@Model.Settings.PromotionText <a href="https://makepay.io" target="_blank" rel="noopener">Enable 90+ currencies with MakePay</a>.</div>
