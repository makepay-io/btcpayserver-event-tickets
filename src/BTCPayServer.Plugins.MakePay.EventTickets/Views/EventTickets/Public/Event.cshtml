@model EventDetailViewModel
@{Layout=null;}<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title>@Model.Event.Name</title><style>:root{--a:@Model.Settings.AccentColor}*{box-sizing:border-box}body{margin:0;background:#fff7ed;color:#292018;font:16px/1.5 system-ui}.shell{max-width:980px;margin:auto;padding:35px 24px}.hero{background:#fff;border-radius:24px;overflow:hidden;box-shadow:0 18px 50px #7c2d1210}.banner{width:100%;max-height:420px;object-fit:cover}.intro{padding:30px}.types{margin-top:30px;display:grid;gap:18px}.type{background:#fff;border:1px solid #fed7aa;border-radius:18px;padding:24px;display:grid;grid-template-columns:1fr auto;gap:20px}.price{font-size:1.4rem;font-weight:800}.buy{grid-column:1/-1;display:grid;grid-template-columns:2fr 1fr 1fr auto;gap:10px}.buy input,.buy select{padding:11px;border:1px solid #d9c7b5;border-radius:10px}.buy button{background:var(--a);color:#fff;border:0;border-radius:10px;padding:11px 20px;font-weight:750}.sold{color:#b91c1c}@@media(max-width:700px){.buy{grid-template-columns:1fr}.type{grid-template-columns:1fr}}</style></head><body><main class="shell"><article class="hero">@if(Model.Event.BannerUrl is not null){<img class="banner" src="@Model.Event.BannerUrl" alt="">}<div class="intro"><h1>@Model.Event.Name</h1><p>@Model.Event.StartsAt.ToString("dddd, dd MMMM yyyy · HH:mm") — @Model.Event.EndsAt.ToString("HH:mm")</p><p><strong>@Model.Event.VenueName</strong><br>@Model.Event.VenueAddress</p><p>@Model.Event.Description</p>@if(Model.PosMode){<strong>POS mode</strong>}</div></article><section class="types">@foreach(var t in Model.Event.TicketTypes.Where(t=>t.Active)){var remaining=Model.Remaining[t.Id];<article class="type"><div><h2>@t.Name</h2><p>@t.Description</p><span class="@(remaining==0?"sold":"")">@(remaining is null?"Available":remaining+" remaining")</span></div><div class="price">@t.Price.ToString("0.00") @Model.Settings.Currency</div>@if(remaining!=0){<form class="buy" method="post" asp-action="Buy" asp-route-storeId="@Model.StoreId" asp-route-eventId="@Model.Event.Id"><input type="hidden" name="ticketTypeId" value="@t.Id"><input type="hidden" name="pos" value="@Model.PosMode"><input name="buyerName" required placeholder="Attendee / buyer name"><input name="email" type="email" required placeholder="Email"><select name="quantity">@for(var q=1;q<=Math.Min(t.MaxPerOrder,remaining??t.MaxPerOrder);q++){<option value="@q">@q</option>}</select><button>Pay</button></form>}</article>}</section></main></body></html>
