@model TicketCheckoutPageViewModel
@{ Layout = null; var eventOnSale = TicketEventSalePolicy.CanStartCheckout(Model.Event, DateTimeOffset.UtcNow); var promoInvalid = !string.IsNullOrWhiteSpace(Model.PromoMessage) && Model.Order.PromoCode is null; var analyticsEcommerce = TicketAnalytics.ForOrder(Model.Order, Model.Event, Model.Lines); var analyticsOrderId = TicketAnalytics.AnalyticsTransactionId(Model.Order); var analyticsContext = new EventTicketAnalyticsContext { Settings = Model.Settings, StoreId = Model.StoreId, PageType = "cart", EventId = Model.Event.Id, EventSlug = Model.Event.Slug }; }
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Cart · @Model.Event.Name</title>
    <partial name="~/Views/EventTickets/Public/_Theme.cshtml" model="Model.Settings" />
</head>
<body class="et-public">
<partial name="~/Views/EventTickets/Public/_Analytics.cshtml" model="analyticsContext" />
<partial name="~/Views/EventTickets/Public/_Countdown.cshtml" model="Model" />
<main class="et-checkout-shell">
    <partial name="~/Views/EventTickets/Public/_Stepper.cshtml" model="Model.Step" />
    @if (Model.Order.Status == TicketOrderStatus.Cancelled)
    {
        <section class="et-pending">
            <h1>This reservation has ended</h1>
            <p class="et-section-copy">@(eventOnSale ? "Your tickets were released. Rebuy reserves the same selection in a fresh session." : "Your tickets were released, and this event is no longer on sale. Browse the current events to continue.")</p>
            <div class="et-restart-actions">
                @if (eventOnSale)
                {
                    <form method="post" asp-action="Rebuy" asp-route-storeId="@(Model.CleanUrls ? null : Model.StoreId)" asp-route-eventId="@Model.Event.Slug" asp-route-orderId="@Model.Order.Id" asp-route-accessToken="@Model.AccessToken">
                        <button class="et-primary" type="submit" data-loading-title="Reserving your tickets…" data-loading-message="We are creating a fresh reservation with your previous selection.">Rebuy tickets</button>
                    </form>
                    <a class="et-secondary" asp-action="Event" asp-route-storeId="@(Model.CleanUrls ? null : Model.StoreId)" asp-route-eventId="@Model.Event.Slug">Choose different tickets</a>
                }
                <a class="et-secondary" asp-action="Storefront" asp-route-storeId="@(Model.CleanUrls ? null : Model.StoreId)">Browse events</a>
            </div>
        </section>
    }
    else
    {
        <section>
            <h1 class="et-section-heading">Review your cart</h1>
            <p class="et-section-copy">Your ticket selection is reserved while the timer is running.</p>
            <div class="et-card">
                <div class="et-cart-head"><span>Ticket</span><span>Price</span><span>Qty</span><span>Total</span></div>
                @foreach (var line in Model.Lines)
                {
                    <div class="et-cart-row">
                        <strong>@line.TicketType.Name</strong>
                        <span>@line.Line.UnitPrice.ToString("0.##") @Model.Order.Currency</span>
                        <span>@line.Line.Quantity</span>
                        <strong>@line.Total.ToString("0.##") @Model.Order.Currency</strong>
                    </div>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Settings.PromoCode) && Model.Settings.PromoPercent > 0)
            {
                <form class="et-promo-card" method="post" asp-action="ApplyPromotion" asp-route-storeId="@(Model.CleanUrls ? null : Model.StoreId)" asp-route-eventId="@Model.Event.Slug" asp-route-orderId="@Model.Order.Id" asp-route-accessToken="@Model.AccessToken" data-loading-title="Applying your promotion…" data-loading-message="We are updating the reserved ticket total.">
                    <h3>Have a promotion code?</h3>
                    <p id="promo-description">@Model.Settings.PromoDescription</p>
                    <label for="promo-code">Promotion code</label>
                    <div class="et-inline-form">
                        <input class="et-input" id="promo-code" name="promoCode" value="@Model.Order.PromoCode" maxlength="80" autocomplete="off" autocapitalize="characters" spellcheck="false" placeholder="Enter your code" aria-describedby="promo-description promo-result" aria-invalid="@(promoInvalid ? "true" : null)">
                        <button class="et-secondary" type="submit" data-et-requires-session>Apply</button>
                    </div>
                    <div id="promo-result" class="@(promoInvalid ? "et-validation" : "")" role="status" aria-live="polite">@Model.PromoMessage</div>
                </form>
            }
            <div class="et-summary">
                <div class="et-summary-row"><span>Subtotal</span><strong>@Model.Order.Subtotal.ToString("0.##") @Model.Order.Currency</strong></div>
                @if (Model.Order.DiscountAmount > 0) { <div class="et-summary-row"><span>Promotion @Model.Order.PromoCode</span><strong>−@Model.Order.DiscountAmount.ToString("0.##") @Model.Order.Currency</strong></div> }
                <div class="et-summary-row total"><span>Total</span><strong>@Model.Order.Total.ToString("0.##") @Model.Order.Currency</strong></div>
            </div>
            <div class="et-actions">
                <a class="et-secondary" asp-action="@(Model.Order.PosMode ? "Pos" : "Event")" asp-route-storeId="@(Model.CleanUrls ? null : Model.StoreId)" asp-route-eventId="@Model.Event.Slug">Back</a>
                <a class="et-primary" data-et-requires-session data-begin-checkout asp-action="Details" asp-route-storeId="@(Model.CleanUrls ? null : Model.StoreId)" asp-route-eventId="@Model.Event.Slug" asp-route-orderId="@Model.Order.Id" asp-route-accessToken="@Model.AccessToken">Continue</a>
            </div>
        </section>
    }
    <partial name="~/Views/EventTickets/Public/_Footer.cshtml" model="Model.Settings" />
</main>
@if (Model.Order.Status == TicketOrderStatus.Pending)
{
    <script>
    (()=>{const ecommerce=@Html.Raw(System.Text.Json.JsonSerializer.Serialize(analyticsEcommerce)),analytics=window.makePayAnalytics,analyticsOrderId=@Html.Raw(System.Text.Json.JsonSerializer.Serialize(analyticsOrderId));analytics?.trackOnce('add_to_cart',analyticsOrderId,{ecommerce},'local');analytics?.track('view_cart',{ecommerce});document.querySelector('[data-begin-checkout]')?.addEventListener('click',()=>analytics?.trackOnce('begin_checkout',analyticsOrderId,{ecommerce}))})();
    </script>
}
</body>
</html>
